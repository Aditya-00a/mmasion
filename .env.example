# Local worker model
MMASION_PROVIDER=ollama
MMASION_OLLAMA_MODEL=gemma3:12b

# Passive supervision monitor
# Set to `gemini` to force Gemini API monitoring when an API key is available.
# Set to `vertex` to force Vertex bearer-token monitoring when Vertex credentials are available.
MMASION_MONITOR_PROVIDER=auto
MMASION_VERTEX_MODEL=gemini-2.5-flash
MMASION_VERTEX_LOCATION=us-central1

# Choose one auth path for Gemini/Vertex:
# 1. Gemini API key path
GEMINI_API_KEY=
MMASION_GEMINI_API_KEY=

# 2. Bearer token path
MMASION_VERTEX_PROJECT_ID=
MMASION_VERTEX_ACCESS_TOKEN=

# Optional Google audio path for server-side STT / TTS
MMASION_GOOGLE_ACCESS_TOKEN=
MMASION_TTS_VOICE_NAME=
